# Required for Gemini AI API calls.
# Obtain from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Required for Firebase integration
FIREBASE_PROJECT_ID=

# Required for COA cryptographic signing (HMAC-SHA256)
# Set a strong random string; the server will refuse to sign without it.
COA_SIGNING_SECRET=

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3000"

# Administration & GxP auditor email config
ADMIN_EMAIL="admin@hempforge.lan"
VITE_ADMIN_EMAIL="admin@hempforge.lan"

# Optional: Use local in-memory DB fallback instead of Firestore (dev only)
# USE_LOCAL_DB_FALLBACK=true
