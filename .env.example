# ──────────────────────────────────────────────────────────────────────────────
# HempForge — environment configuration
# ──────────────────────────────────────────────────────────────────────────────
# Variables marked REQUIRED will cause the server to refuse to start in
# production (NODE_ENV=production) if missing or invalid. In development
# they may be omitted — warnings are printed at boot.

# ─── Node runtime ─────────────────────────────────────────────────────────────
# Set to "production" for deployed environments. Anything else is treated as
# development and enables the dev-token middleware (see authMiddleware).
NODE_ENV=development

# ─── Required in production ───────────────────────────────────────────────────
# Gemini AI API key. Format: AIzaSy...  Get one at https://aistudio.google.com/apikey
# Production refuses to start without this.
GEMINI_API_KEY=

# Firebase project ID. Must match the firebase-applet-config.json projectId.
# Production refuses to start without this.
FIREBASE_PROJECT_ID=

# HMAC-SHA256 secret used to sign COAs. Must be at least 32 characters.
# Production refuses to start without this. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
COA_SIGNING_SECRET=

# Service account credentials. EITHER set this JSON string, OR run with
# Application Default Credentials (e.g. `gcloud auth application-default login`).
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Comma-separated allow-list of origins permitted to call the API.
# REQUIRED in production — server refuses to start without it.
# Example: CORS_ORIGIN=https://app.hempforge.com,https://admin.hempforge.com
CORS_ORIGIN=

# ─── Optional ────────────────────────────────────────────────────────────────
# Public URL where the applet is hosted (used for COA verification links).
APP_URL="http://localhost:3000"

# Administration & GxP auditor email. Used as a hint by deriveTenantAndRole
# in non-production environments only — production enforces custom claims.
ADMIN_EMAIL="admin@hempforge.lan"
VITE_ADMIN_EMAIL="admin@hempforge.lan"

# Use local in-memory DB fallback instead of Firestore (dev only).
# When true, all data is written to local-db-fallback.json and lost on restart.
USE_LOCAL_DB_FALLBACK=true

# ─── Dev-token authentication (NEVER set in production) ─────────────────────
# When NODE_ENV is not "production", the API accepts bearer tokens of the
# form:   dev-<uid>:<email>:<tenantId>:<role>
# Example: dev-alice:alice@acme.test:tenant-acme:Lab%20Admin
# Production authMiddleware returns 401 for any token starting with "dev-".
# ─────────────────────────────────────────────────────────────────────────────